---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';
const { brand, seo } = config;
---
<Layout title={seo?.title || 'Grazie Mille'}>
    <main class="relative min-h-screen">
        <!-- Ambient Background -->
        <div class="fixed inset-0 pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-champagne/10 blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-blue-900/10 blur-[120px]"></div>
        </div>

        <!-- Hero Section -->
        <section class="relative pt-32 pb-20 px-8 flex flex-col items-center text-center max-w-7xl mx-auto">
            <div class="inline-block px-4 py-1 mb-6 rounded-full glass text-[10px] tracking-[0.2em] uppercase text-champagne font-bold">
                Exclusively for the Discerning
            </div>
            <h1 class="text-6xl md:text-8xl font-medium leading-tight mb-8 max-w-4xl">
                The Art of <span class="italic text-champagne">Gratitude</span>, Redefined.
            </h1>
            <p class="text-lg md:text-xl text-silk/60 max-w-2xl mb-12 font-light leading-relaxed">
                Grazie Mille bridges the gap between desire and reality, offering bespoke concierge services and luxury curation for those who demand the extraordinary.
            </p>
            <div class="flex flex-col sm:flex-row gap-6">
                <a href="#contact" class="px-10 py-4 bg-champagne text-obsidian font-bold rounded-full hover:scale-105 transition-transform duration-300 cursor-pointer">
                    Request VIP Access
                </a>
                <a href="#services" class="px-10 py-4 glass text-silk font-medium rounded-full hover:bg-white/10 transition-colors duration-300">
                    Explore the Atelier
                </a>
            </div>
        </section>

        <!-- Bento Grid Section -->
        <section id="services" class="relative py-24 px-8 max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Large Tile: Hero Service -->
                <div class="md:col-span-2 md:row-span-2 relative group overflow-hidden rounded-3xl glass min-h-[500px] flex flex-col justify-end p-10 transition-all duration-500 hover:border-champagne/50">
                    <div class="absolute inset-0 bg-gradient-to-t from-obsidian via-obsidian/20 to-transparent z-10"></div>
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1542314831-068cd1db Xinjiang')] bg-cover bg-center group-hover:scale-110 transition-transform duration-700"></div>
                    <div class="relative z-20">
                        <h3 class="text-4xl font-medium mb-4">Bespoke Experiences</h3>
                        <p class="text-silk/70 max-w-md mb-6">From private islands to closed-door galleries, we curate moments that money cannot buy.</p>
                        <button class="text-champagne font-bold flex items-center gap-2 group-hover:gap-4 transition-all">
                        Discover More <span>&rarr;</span>
                        </button>
                    </div>
                </div>

                <!-- Medium Tile: Value Prop -->
                <div class="glass rounded-3xl p-8 flex flex-col justify-between hover:border-champagne/30 transition-all group">
                    <div class="w-12 h-12 rounded-2xl bg-champagne/20 flex items-center justify-center text-champagne mb-6 group-hover:rotate-12 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14m-5 7v-5m-5 5v-5" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-2xl font-medium mb-2">Luxury Atelier</h3>
                        <p class="text-silk/50 text-sm">Curated high-end gifting with global white-glove delivery.</p>
                    </div>
                </div>

                <!-- Small Tile: Trust Signal -->
                <div class="glass rounded-3xl p-8 flex flex-col items-center justify-center text-center hover:border-champagne/30 transition-all">
                    <span class="text-4xl font-black text-champagne mb-2">500+</span>
                    <span class="text-xs uppercase tracking-widest text-silk/40">Elite Members</span>
                </div>

                <!-- Small Tile: Quick Quote Form -->
                <div class="glass rounded-3xl p-8 flex flex-col justify-between hover:border-champagne/30 transition-all">
                    <h3 class="text-lg font-medium mb-4">Quick Inquiry</h3>
                    <form class="space-y-3">
                        <input type="email" placeholder="Email Address" class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs focus:outline-none focus:border-champagne transition-colors" />
                        <button class="w-full py-2 bg-champagne text-obsidian text-xs font-bold rounded-lg uppercase tracking-tighter">Send Request</button>
                    </form>
                </div>
            </div>
        </section>

        <!-- VIP Call to Action -->
        <section class="relative py-32 px-8 text-center">
            <div class="max-w-3xl mx-auto glass p-16 rounded-[4rem] border-champagne/20 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-champagne to-transparent"></div>
                <h2 class="text-4xl md:text-5xl font-medium mb-6">Enter the Inner Circle</h2>
                <p class="text-silk/60 mb-10 leading-relaxed">Membership is by invitation or referral only. Apply for a private consultation to unlock the full suite of Grazie Mille services.</p>
                <button class="px-12 py-5 bg-silk text-obsidian font-black rounded-full hover:bg-champagne transition-colors duration-300 uppercase tracking-widest text-sm">
                    Apply for Membership
                </button>
            </div>
        </section>

        <footer class="py-12 px-8 border-t border-white/5 text-center text-silk/30 text-xs tracking-widest uppercase">
            &copy; {new Date().getFullYear()} Grazie Mille. All Rights Reserved. Digital Couture by AI Swarm.
        </footer>
    </main>
</Layout>